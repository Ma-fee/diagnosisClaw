# Xeno-Agent Environment Variables

# LLM Configuration
# Base URL for LLM API
XENO_LLM_API_BASE=http://api.ai.rootcloud.info/v1

# Model name to use (format: provider/model)
# For OpenAI-compatible APIs, use: openai/model_name
XENO_LLM_MODEL=openai/glm-4.7

# API key for LLM authentication (if required)
# XENO_LLM_API_KEY=your_api_key_here

