FROM egslingjun-registry.cn-wulanchabu.cr.aliyuncs.com/egslingjun/inference-xpu-pytorch:25.01-v1.4.1-vllm0.6.4.post1-torch2.5-cuda12.3-20250115

# 安装基础依赖
RUN apt update && \
    apt install -y libre2-dev && \
    apt install -y libb64-dev && \
    apt install -y libarchive-dev && \
    apt install -y rapidjson-dev && \
    apt install -y libxml2-dev && \
    apt install -y libcurl4-openssl-dev && \
    apt install -y patchelf && \
    rm -rf /var/lib/apt/lists/*

# 拷贝并解压tritonserver.tar
ADD tritonserver.tar /opt/
RUN ln -sf /opt/tritonserver/bin/tritonserver /usr/bin/tritonserver

# 设置入口点
CMD ["/opt/tritonserver/bin/tritonserver"]
