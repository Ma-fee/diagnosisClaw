ARG ACS_PPU_VERSION="25.05-v1.5.1-vllm0.8.5-torch2.6-cu126-20250604"
FROM egslingjun-registry.cn-wulanchabu.cr.aliyuncs.com/egslingjun/inference-xpu-pytorch:${ACS_PPU_VERSION}

# 安装基础依赖
RUN apt-get update && \
    apt-get install -y --no-install-recommends runit && \
    rm -rf /var/lib/apt/lists/*

# 启动 runit
CMD ["runsvdir", "-P", "/etc/service"]
